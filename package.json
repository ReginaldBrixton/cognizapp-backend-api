{
  "name": "cognizapp-backend-api",
  "type": "module",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run dev:all",
    "dev:all": "concurrently -k -n server,lint -c blue,magenta \"bun run dev:server\" \"bun run lint:watch\"",
    "dev:server": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun run typecheck",
    "lint": "biome check src/app src/config src/index.ts src/server.ts package.json playwright.config.ts biome.json",
    "lint:fix": "biome check --write src/app src/config src/index.ts src/server.ts package.json playwright.config.ts biome.json",
    "lint:watch": "bun run scripts/dev-lint-watch.mjs",
    "test": "bun test --max-concurrency 1 tests",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright test --reporter=html && playwright show-report"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/swagger": "^1.3.1",
    "@google/genai": "^2.4.0",
    "@sinclair/typebox": "^0.34.41",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.3.1",
    "elysia": "^1.4.29",
    "firebase-admin": "^14.0.0",
    "jose": "^5",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.6",
    "redis": "^5.12.1",
    "uploadthing": "^7.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@playwright/test": "^1.58.2",
    "bun-types": "latest",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}
